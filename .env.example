# Trackify environment variables
# Copy this file to ".env" and fill in your values, then restart `expo start`.
#
# Anything prefixed with EXPO_PUBLIC_ is bundled into the app and visible to
# clients. Only put PUBLIC, non-secret values here — the Supabase anon key and
# your backend URL are safe (RLS protects the data). Keep real AI provider keys
# on the backend (see /server), NOT here.

# --- Backend (recommended for production) ---------------------------------
# URL of the Trackify server you deployed (Render/Heroku). When set, AI runs
# through it and no AI key needs to live in the app. Leave blank to use the
# on-device key below or local fallback summaries.
# Local dev on a phone: use your computer's LAN IP, e.g. http://192.168.1.20:8080
EXPO_PUBLIC_API_URL=

# --- Supabase (cloud auth + sync + realtime) ------------------------------
# From Supabase → Project Settings → API. Both are PUBLIC and safe to ship.
# Run database.sql in the Supabase SQL Editor first.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional: direct AI key for local dev only ---------------------------
# If you DON'T run the backend, you can paste an xAI (Grok) key here (or in-app
# under Settings → Trackify AI). Get one at https://console.x.ai
EXPO_PUBLIC_GROK_API_KEY=
EXPO_PUBLIC_GROK_MODEL=
EXPO_PUBLIC_GROK_BASE_URL=

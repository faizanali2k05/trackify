# Spendify environment variables
# Copy this file to ".env" and fill in your values, then restart `expo start`.
#
# Anything prefixed with EXPO_PUBLIC_ is bundled into the app and visible to
# clients. For a real launch, proxy AI calls through a server and keep the key
# there. For local development, EXPO_PUBLIC_ is fine.

# Your xAI (Grok) API key — get one at https://console.x.ai
# You can also paste this key in-app under Settings → Spendify AI instead.
EXPO_PUBLIC_GROK_API_KEY=

# Optional: override the Grok model (default: grok-3). Examples: grok-4, grok-3-mini
EXPO_PUBLIC_GROK_MODEL=

# Optional: override the API base URL (default: https://api.x.ai/v1)
EXPO_PUBLIC_GROK_BASE_URL=

# Optional: Supabase (cloud sync is stubbed and off by default)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

{
  "expo": {
    "name": "Trackify",
    "slug": "trackify",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "trackify",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/ios/AppIcon-1024.png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trackify.app"
    },
    "android": {
      "package": "com.trackify.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/icon-white.png",
        "backgroundColor": "#06B58F"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/web/favicon/favicon-512.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font",
      "expo-asset",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/icon-white.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0A0C0B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}

# Trackify backend environment.
# Copy to server/.env for local dev (`cd server && npm install && npm run dev`).
# On Render/Heroku, set these in the dashboard instead of committing them.

# Port (Render/Heroku inject this automatically; default 8080 locally).
PORT=8080

# Which AI provider to use: grok | openai | gemini
AI_PROVIDER=grok

# --- Grok / xAI (default, OpenAI-compatible) ---
GROK_API_KEY=
GROK_MODEL=grok-3
GROK_BASE_URL=https://api.x.ai/v1

# --- OpenAI (if AI_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Google Gemini (if AI_PROVIDER=gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
